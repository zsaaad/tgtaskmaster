{
  "hosting": {
    "public": ".",
    "ignore": [
      ".git/**",
      ".vscode/**",
      ".claude/**",
      ".gitignore",
      ".firebaserc",
      "firebase.json",
      "firebase-config.example.js",
      "firestore.rules",
      "public/**",
      "node_modules/**",
      "*.md",
      "*.log"
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
        ]
      }
    ]
  }
}
